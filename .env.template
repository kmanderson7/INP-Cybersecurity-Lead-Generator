# INP² B2B Lead Generator — Environment Variables Template
# Copy this file to .env and fill in actual values.
# Set REQUIRE_LIVE_DATA=true in production to block all mock/stub fallbacks.

# ── Core AI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Apollo (Lead & Contact Search) ───────────────────────────────────────────
# Primary Apollo key — used by all cybersecurity-profile searches
APOLLO_API_KEY=your_apollo_api_key_here
# Dedicated Laminar key — used by Apollo Prospector + Laminar Pilot view
# when 'commodity_trading' profile is active
APOLLO_LAMINAR_API_KEY=your_apollo_laminar_api_key_here

# ── News & Search Intelligence ────────────────────────────────────────────────
# NewsAPI — used by news-leads, breach-proximity, exec-moves
NEWS_API_KEY=your_newsapi_key_here
# SerpAPI Google News — used by exec-moves for CISO/CTO appointment news
SERPAPI_API_KEY=your_serpapi_key_here
# JSearch (RapidAPI) — used by workforce-stress for job-opening data
JSEARCH_RAPIDAPI_KEY=your_jsearch_rapidapi_key_here

# ── Federal Procurement ───────────────────────────────────────────────────────
# SAM.gov — used by rfp-hunter (free with registration at sam.gov)
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# ── Email Send ────────────────────────────────────────────────────────────────
# Choose one provider: 'sendgrid' (default) or 'mailgun'
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key_here
MAILGUN_API_KEY=your_mailgun_key_here
MAILGUN_DOMAIN=your_mailgun_domain_here
# Sender address used in outbound emails
FROM_EMAIL=noreply@inp2.com
# Set to "true" to actually send; otherwise send-email simulates
EMAIL_SERVICE_ENABLED=false
# Organizer address used in calendar invites from schedule-call
ORGANIZER_EMAIL=noreply@inp2.com

# ── State Persistence (Supabase) ──────────────────────────────────────────────
# Optional: enables cross-device state sync via state-save / state-load functions
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_APP_STATE_TABLE=app_state

# ── Runtime Behavior ──────────────────────────────────────────────────────────
# Set to "true" in production to block all mock/stub fallbacks (returns 503 instead)
REQUIRE_LIVE_DATA=true
# Bot identity header used by web-scraping fallbacks
USER_AGENT="INP2-LeadGen-Bot/1.0"
# Per-IP rate limit
MAX_REQUESTS_PER_HOUR=100
# How long to cache provider responses (hours)
CACHE_TTL_HOURS=24

# ── Development ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
