# INP² Cybersecurity Lead Generator - Environment Variables Template

# AI Integration (Required for signal analysis and lead intelligence)
OPENAI_API_KEY=your_openai_api_key_here

# Lead Generation APIs (Free tiers available)
APOLLO_API_KEY=your_apollo_api_key_here
# Apollo key dedicated to the Laminar / commodity-trading prospecting profile (CFO, Treasurer, oil & gas, midstream)
# Used by Apollo Prospector + Laminar Pilot view when 'commodity_trading' profile is active
APOLLO_LAMINAR_API_KEY=your_apollo_laminar_api_key_here
# NewsAPI key — used by news-leads, breach-proximity, and exec-moves (note: variable name uses underscore)
NEWS_API_KEY=your_newsapi_key_here
# SerpAPI Google News results — used by exec-moves for CISO/CTO appointment news (free tier ~100 searches/mo)
SERPAPI_API_KEY=your_serpapi_key_here
# SAM.gov federal opportunities feed — used by rfp-hunter (free with registration at sam.gov)
SAM_GOV_API_KEY=your_sam_gov_api_key_here

# Contact Enrichment (Free credits available)
PEOPLEDATALABS_API_KEY=your_pdl_api_key_here
HUNTER_API_KEY=your_hunter_io_api_key_here
SNOV_API_KEY=your_snov_io_api_key_here
LUSHA_API_KEY=your_lusha_api_key_here
CLEARBIT_API_KEY=your_clearbit_api_key_here

# Email & Communication (Optional)
MAILGUN_API_KEY=your_mailgun_key_here
SENDGRID_API_KEY=your_sendgrid_key_here
# Set to "true" to actually send email; otherwise schedule-call and send-email simulate
EMAIL_SERVICE_ENABLED=false
# Organizer address used in calendar invites generated by schedule-call
ORGANIZER_EMAIL=noreply@inp2.com

# CRM Integration (Optional)
SALESFORCE_CLIENT_ID=your_sf_client_id_here
SALESFORCE_CLIENT_SECRET=your_sf_client_secret_here
HUBSPOT_API_KEY=your_hubspot_key_here

# Web Scraping & Intelligence
USER_AGENT="INP2-LeadGen-Bot/1.0"
PROXY_URL=your_proxy_url_here_if_needed

# Rate Limiting & Security
MAX_REQUESTS_PER_HOUR=100
CACHE_TTL_HOURS=24

# Development Settings
NODE_ENV=development
LOG_LEVEL=info

# Premium API Keys:
CRUNCHBASE_API_KEY - Funding data                                                                                                                                 │ │
LINKEDIN_API_KEY - Professional network data                                                                                                                      │ │
CLEARBIT_API_KEY - Company enrichment                                                                                                                             │ │
ZOOMINFO_API_KEY - Enhanced B2B data                                                                                                                              │ │
PITCHBOOK_API_KEY - Investment intelligence    
# Usage Instructions:
# 1. Copy this file to .env
# 2. Replace placeholder values with your actual API keys
# 3. Free tier accounts available for most services:
#    - OpenAI: $5 credit for new accounts
#    - Apollo: Free plan with limited credits
#    - People Data Labs: 100 free enrichments/month
#    - Hunter.io: 50 free searches/month
#    - NewsAPI: Free tier with 1000 requests/day
# 4. Only OPENAI_API_KEY is required for basic functionality